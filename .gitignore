# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-dev/
/out/

# production/build outputs
/build
/dist/
/dist_electron/
/release/
/releases/
/app/

# misc
.DS_Store
*.pem
*.log
*.local

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local runtime data
/data/rules.json
/logs/

# local agent/tool state
/.codegraph/
/.chatboks/
/.cursor/

# bundled/local binaries
/ollama.exe

# electron-builder output
*.blockmap
*.dmg
*.AppImage
*.deb
*.rpm
*.msi
*.nupkg

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
